# Configuración de Variables de Entorno - SherpaTravelScraper

# ============================================
# CONEXIÓN A BASE DE DATOS
# ============================================
DB_SERVER=192.168.5.112
DB_DATABASE=TravelRequirementsDB
DB_USER=sa
DB_PASSWORD=tu_password_seguro_aqui
DB_TRUST_CERTIFICATE=True

# ============================================
# API KEYS - IA Y SERVICIOS
# ============================================

# OpenRouter API (para extracción con IA)
OPENROUTER_API_KEY=sk-or-v1-tu_api_key_aqui

# Kimi/Moonshot API (alternativa para extracción con IA)
KIMI_API_KEY=sk-kimi-tu_api_key_aqui

# ============================================
# CONFIGURACIÓN DE IA (Opcional)
# ============================================

# Proveedor de IA preferido: openrouter, kimi, ollama
AI_PROVIDER=openrouter
AI_ENABLED=true

# Configuración de Ollama (si se usa)
OLLAMA_ENDPOINT=http://localhost:11434/api/generate
OLLAMA_VISION_ENDPOINT=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3.2-vision:latest

# ============================================
# CONFIGURACIÓN DE PLAYWRIGHT
# ============================================
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSER=Chromium

# ============================================
# CONFIGURACIÓN DE SCRAPING
# ============================================
SCRAPING_DELAY_MIN=3
SCRAPING_DELAY_MAX=8
SCRAPING_MAX_REINTENTOS=3
SCRAPING_NAVIGATION_TIMEOUT=20000
SCRAPING_SELECTOR_TIMEOUT=15000

# ============================================
# CONFIGURACIÓN DE LOGGING
# ============================================
LOG_LEVEL=Information
